# ===========================================================

# Penda BACKEND ENVIRONMENT CONFIGURATION
# ===========================================================

# APP ENVIRONMENT
APP_NAME=Penda
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost/penda_backend/public
APP_TIMEZONE=Africa/Nairobi
APP_LOCALE=en

# ===========================================================
# DATABASE CONFIGURATION (MySQL 8)
# ===========================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=penda_backend
DB_USERNAME=penda_backend
DB_PASSWORD=10489635
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

# ===========================================================
# REDIS CONFIGURATION
# ===========================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

# ===========================================================
# JWT CONFIGURATION (for AuthService & Middleware)
# ===========================================================
JWT_SECRET=180ffdb728a6acbea5ba1978168051851c81c55ac3807a8defb5733b3667070ae70a689148719662a0ce750e8d276da3ded6dcb7781d7637897f95d57b63b76d
JWT_ALGO=HS256
# Token validity in seconds
JWT_TTL=86400    
# Refresh token validity in seconds       
JWT_REFRESH_TTL=86400  
# Access token expiry (seconds)
JWT_ACCESS_TTL=900
# Refresh token expiry (seconds)
JWT_REFRESH_TTL=604800
# Allow multiple device login
JWT_ALLOW_MULTI_DEVICE=true
# Token issuer
JWT_ISSUER=pendaBackend
# Token audience
JWT_AUDIENCE=pendaMobileApp

# ===========================================================
# CLOUDINARY CONFIGURATION (Photo Uploads)
# ===========================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=Penda-uploads

# ===========================================================
# PAYMENT PROVIDERS
# ===========================================================
# M-PESA
MPESA_SHORTCODE=174379
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENV=sandbox

# Airtel Money
AIRTEL_CONSUMER_KEY=your_airtel_key
AIRTEL_CONSUMER_SECRET=your_airtel_secret
AIRTEL_ENV=sandbox

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ===========================================================
# SMS SERVICE (for OTP & notifications)
# ===========================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+254700000000

# ===========================================================
# EMAIL SERVICE (for notifications & reports)
# ===========================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@Penda.app
MAIL_FROM_NAME="Penda App"

# ===========================================================
# CRON JOBS CONFIGURATION
# ===========================================================
# seconds
CRON_TEMP_UPLOAD_RETENTION=3600       
CRON_LOG_PRUNE_DAYS=30
CRON_SUBSCRIPTION_NOTIFY_DAYS=3

# ===========================================================
# DEFAULT USER SETTINGS
# ===========================================================
DEFAULT_LANGUAGE=en
DEFAULT_NOTIFICATIONS_ENABLED=true
DEFAULT_SHOW_ONLINE_STATUS=true
DEFAULT_SHOW_DISTANCE=true

# ===========================================================
# OTHER SETTINGS
# ===========================================================
# 5 MB
MAX_UPLOAD_SIZE=5242880  
ALLOWED_UPLOAD_TYPES=jpg,jpeg,png,gif,mp4
DEFAULT_COUNTRY=Kenya

# ===========================================================
# FEATURE FLAGS
# ===========================================================
FEATURE_PREMIUM_DISCOVER=true
FEATURE_SUPERLIKE=true
FEATURE_DAILY_DIGEST=true
FEATURE_BLOCK_USER=true
FEATURE_REPORT_USER=true

# ===========================================================
# LOGGING CONFIGURATION
# ===========================================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ===========================================================
# THIRD-PARTY API KEYS
# ===========================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ===========================================================
# SECURITY SETTINGS
# ===========================================================
PASSWORD_HASH_ALGO=bcrypt
PASSWORD_HASH_COST=12
# Force HTTPS in production
FORCE_HTTPS=true
# Secure cookies
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAMESITE=Strict
# Maximum login attempts before temporary block
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_DURATION=900

# ===========================================================
# TESTING CONFIGURATION
# ===========================================================
TEST_DB_CONNECTION=mysql
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_DATABASE=penda_test
TEST_DB_USERNAME=root
TEST_DB_PASSWORD=your_mysql_password

# ===========================================================
# BACKUP CONFIGURATION
# ===========================================================
BACKUP_DISK=local
BACKUP_PATH=/backups
BACKUP_SCHEDULE=daily

# ===========================================================
# MAINTENANCE MODE MESSAGE
# ===========================================================
MAINTENANCE_MODE_MESSAGE="The Penda app is currently undergoing maintenance. Please check back later."

# ===========================================================
# API RATE LIMITING
# ===========================================================
API_RATE_LIMIT=1000
# seconds
API_RATE_LIMIT_WINDOW=60  

# ===========================================================
# CORS CONFIGURATION
# ===========================================================

CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=true
CRON_REFRESH_TOKEN_PRUNE_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://penda.local

