{
    "name": "malik/penda-backend",
    "description": "Penda Backend",
    "type": "project",
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^7.0",
        "predis/predis": "^2.3",
        "guzzlehttp/guzzle": "^7.8",
        "cloudinary/cloudinary_php": "^2.9",
        "phpmailer/phpmailer": "^7.0",
        "twilio/sdk": "^8.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}
